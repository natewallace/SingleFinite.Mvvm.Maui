<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="using:Example.App.Views"
    xmlns:singleFinite="clr-namespace:SingleFinite.Mvvm.Maui;assembly=SingleFinite.Mvvm.Maui">

    <Style TargetType="local:MainWindowContentPage">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />
    </Style>

    <Style TargetType="singleFinite:DialogViewPresenter">
        <Setter Property="DialogBackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />
    </Style>

</ResourceDictionary>
